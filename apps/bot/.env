TWITCH_CHANNEL_NAME=
TWITCH_BOT_USERNAME=
TWITCH_CLIENT_ID=
TWITCH_OAUTH_TOKEN=

DISCORD_LINK=

# Proveedor de ajedrez: lichess | chesscom
CHESS_PROVIDER=lichess

# Chess.com (se usa cuando CHESS_PROVIDER=chesscom)
