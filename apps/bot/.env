# Lichess (se usa cuando CHESS_PROVIDER=lichess)
LICHESS_PROFILE_LINK=
LICHESS_TEAM_LINK=
# Usuario de Lichess cuya partida en vivo se emite en el overlay /tv
LICHESS_TV_USER=

# Música (opcional): Client ID gratuito de Jamendo para `npm run setup:music`.
# Créalo en https://devportal.jamendo.com/
JAMENDO_CLIENT_ID=
